# ─────────────────────────────────────────────
# emAIl Sentinel — E2E Playwright Config (TEMPLATE)
# Copy this file to e2e.config.env and fill in every value.
# Never commit e2e.config.env — it is in .gitignore.
# ─────────────────────────────────────────────

# Full path to the dedicated E2E Chrome profile (as shown in chrome://version
# → "Profile Path"). The fixture splits this into the parent user-data-dir and
# profile name automatically — paste the value exactly as Chrome shows it.
# The profile MUST be signed into mail.google.com in a normal Chrome window
# first, and that Chrome window MUST be closed before running the tests.
CHROME_PROFILE_PATH=/path/to/your/chrome/profile

# The Gmail address of the account used for testing.
GOOGLE_EMAIL=your-test-account@gmail.com

# Your Gemini API key (from aistudio.google.com/app/apikey).
GEMINI_API_KEY=

# ── SMS (optional — leave blank to skip Section 9) ────────────────────
# Provider name: textbelt | telnyx | twilio | plivo | clicksend | vonage | webhook
SMS_PROVIDER=

# Credentials — only fill the fields your provider needs:
SMS_API_KEY=           # Textbelt, ClickSend (key), Telnyx, Plivo
SMS_ACCOUNT_SID=       # Twilio / Plivo account SID
SMS_AUTH_TOKEN=        # Twilio auth token or Plivo auth token
SMS_FROM_NUMBER=       # Twilio / Telnyx / Plivo sender number (E.164, e.g. +15550001111)
SMS_USERNAME=          # ClickSend username
SMS_VONAGE_SECRET=     # Vonage API secret
SMS_WEBHOOK_URL=       # Webhook provider HTTPS endpoint

# Your mobile number to receive test SMS (E.164, e.g. +15559876543)
SMS_TEST_NUMBER=

# ── Google Chat (optional — leave blank to skip Section 10) ───────────
# Requires a paid Google Workspace account with Chat enabled.
CHAT_SPACE_NAME=
CHAT_WEBHOOK_URL=

# ── MCP Server (optional — leave blank to skip Section 13) ────────────
MCP_NAME=
# Type: slack | teams | asana | custom
MCP_TYPE=
MCP_ENDPOINT=
MCP_AUTH_TOKEN=

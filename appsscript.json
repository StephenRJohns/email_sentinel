{
  "timeZone": "America/Chicago",
  "dependencies": {
    "enabledAdvancedServices": [
      {
        "userSymbol": "Tasks",
        "version": "v1",
        "serviceId": "tasks"
      }
    ],
    "libraries": [
      {
        "userSymbol": "NotifyLib",
        "version": "2",
        "libraryId": "1YG_5kjmABwYex868cdE6IXXF1Il6ofJnvxXkZ5WDWd3hQo2TozwcQr7R",
        "developmentMode": false
      }
    ]
  },
  "exceptionLogging": "STACKDRIVER",
  "runtimeVersion": "V8",
  "oauthScopes": [
    "https://www.googleapis.com/auth/gmail.addons.execute",
    "https://www.googleapis.com/auth/gmail.readonly",
    "https://www.googleapis.com/auth/calendar",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/tasks",
    "https://www.googleapis.com/auth/script.external_request",
    "https://www.googleapis.com/auth/script.scriptapp"
  ],
  "addOns": {
    "common": {
      "name": "emAIl Sentinel",
      "logoUrl": "https://raw.githubusercontent.com/StephenRJohns/email_sentinel/main/images/ES_32.png",
      "homepageTrigger": {
        "runFunction": "onHomepage",
        "enabled": true
      },
      "universalActions": [
        { "label": "Rules",          "runFunction": "actionShowRules" },
        { "label": "Settings",       "runFunction": "actionShowSettings" },
        { "label": "Activity Log",   "runFunction": "actionShowActivity" },
        { "label": "Help",           "runFunction": "actionShowHelp" },
        { "label": "Scan email now", "runFunction": "actionRunCheckNow" }
      ],
      "openLinkUrlPrefixes": [
        "https://textbelt.com/",
        "https://telnyx.com/",
        "https://console.plivo.com/",
        "https://www.twilio.com/",
        "https://dashboard.clicksend.com/",
        "https://dashboard.nexmo.com/",
        "https://aistudio.google.com/",
        "https://ai.google.dev/",
        "https://chat.google.com/",
        "https://workspace.google.com/",
        "https://modelcontextprotocol.io/",
        "https://github.com/"
      ]
    },
    "gmail": {
      "homepageTrigger": {
        "runFunction": "onHomepage",
        "enabled": true
      }
    }
  }
}
